{
  "$schema": "node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WeChatReader",
  "version": "0.1.0",
  "identifier": "club.refactoring.wechatreader",
  "build": {
    "frontendDist": "dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "WeChatReader",
        "label": "main",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#F4F4F5",
        "center": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' ipc: http://ipc.localhost",
        "script-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost http://localhost:3000 data: ws: https:",
        "img-src": "'self' asset: http://asset.localhost http://localhost:3000 data: blob: https:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "app"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "icon": [
      "../public/wechatreader-logo.png",
      "../public/wechatreader-logo.png",
      "../public/wechatreader-logo.png",
      "../public/wechatreader-logo.png",
      "../public/wechatreader-logo.png"
    ]
  },
  "plugins": {}
}
